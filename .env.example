# Database
DB_PASSWORD=changeme_strong_password
DATABASE_URL=postgresql+asyncpg://notevault:${DB_PASSWORD}@db:5432/notevault
TEST_DATABASE_URL=postgresql+asyncpg://notevault:${DB_PASSWORD}@db:5432/notevault_test

# Redis
REDIS_URL=redis://redis:6379/0

# Security (generate with: make keygen)
SECRET_KEY=your-32-byte-base64-encoded-secret-key
MASTER_KEY=your-32-byte-base64-encoded-master-key

# TOTP — set true on production to enforce 2FA for users who have it enabled
# TOTP_REQUIRED=true

# Registration — set to true only when you want to allow new sign-ups from the public
REGISTRATION_ENABLED=false

# CORS
CORS_ORIGINS=http://localhost:3000
# Restrict allowed HTTP methods and headers (defaults are already minimal)
# CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
# CORS_ALLOWED_HEADERS=Content-Type,Authorization

# Uploads (optional — default 10 MB)
# MAX_UPLOAD_BYTES=10485760

# Bookmarks — show site favicons instead of generic globe icon (default false, privacy-preserving)
# FAVICON_FETCH_ENABLED=false

# Timezone for notification date formatting (IANA name, default: Europe/Rome)
# TIMEZONE=Europe/Rome

# Telegram notifications (optional)
# TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather

# Email notifications via SMTP (optional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=your@gmail.com
# SMTP_TLS=true

# Frontend — optional, defaults to /api (domain-agnostic)
# NEXT_PUBLIC_API_URL=http://localhost:8000

# Deployment (optional)
DEPLOY_HOST=user@your-server.com
DEPLOY_PATH=/opt/notevault
DEPLOY_KEY=~/.ssh/notevault_rsa
