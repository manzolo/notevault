# Deploy overrides — copy to .env.deploy (gitignored) and fill in real values
# These override Makefile defaults without exposing server info to git.

DEPLOY_HOST=root@your-server.lan
DEPLOY_PATH=/root/notevault
# NEXT_PUBLIC_API_URL is now optional — defaults to /api (domain-agnostic).
# Only set if you need absolute URLs (e.g. cross-origin setups).
# NEXT_PUBLIC_API_URL=http://your-domain.lan
