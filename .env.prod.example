# NoteVault — Production environment template
# Copy to .env and fill in real values

# App version — used by docker-compose.prod.yml to pull the right image tag.
# Overridden at deploy time by: make deploy-update APP_VERSION=X.Y.Z
# If omitted, defaults to "latest" (see docker-compose.prod.yml fallback).
# APP_VERSION=x.y.z

# Database
DB_PASSWORD=changeme_strong_password

# Security — generate with: make keygen
SECRET_KEY=your-32-byte-base64-encoded-secret-key
MASTER_KEY=your-32-byte-base64-encoded-master-key

# TOTP — enforce 2FA for users who have it enabled
TOTP_REQUIRED=true

# CORS — set to your public URL
CORS_ORIGINS=http://your-domain.lan

# Uploads (optional — default 10 MB)
# MAX_UPLOAD_BYTES=10485760

# Frontend — optional, defaults to /api (domain-agnostic).
# Set only for cross-origin/custom setups: NEXT_PUBLIC_API_URL=http://your-domain.lan
