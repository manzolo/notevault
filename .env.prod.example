# NoteVault — Production environment template
# Copy to .env and fill in real values

# App version — used by docker-compose.prod.yml to pull the right image tag.
# Overridden at deploy time by: make deploy-update APP_VERSION=X.Y.Z
# If omitted, defaults to "latest" (see docker-compose.prod.yml fallback).
# APP_VERSION=x.y.z

# Database
DB_PASSWORD=changeme_strong_password

# Security — generate with: make keygen
SECRET_KEY=your-32-byte-base64-encoded-secret-key
MASTER_KEY=your-32-byte-base64-encoded-master-key

# TOTP — enforce 2FA for users who have it enabled
TOTP_REQUIRED=true

# Registration — set to true only to allow new sign-ups (default: false)
REGISTRATION_ENABLED=false

# CORS — set to your public URL
CORS_ORIGINS=https://your-domain.com
# Restrict allowed HTTP methods and headers (defaults are already minimal)
# CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
# CORS_ALLOWED_HEADERS=Content-Type,Authorization

# Uploads (optional — default 10 MB)
# MAX_UPLOAD_BYTES=10485760

# Bookmarks — show site favicons instead of generic globe icon (default false, privacy-preserving)
# FAVICON_FETCH_ENABLED=false

# Frontend — optional, defaults to /api (domain-agnostic).
# Set only for cross-origin/custom setups: NEXT_PUBLIC_API_URL=http://your-domain.lan

# Timezone for notification date formatting (IANA name, default: Europe/Rome)
# TIMEZONE=Europe/Rome

# Daily journal note title format:
# - iso (default) -> 2026-04-20
# - localized_long -> Monday 20 April 2026 / Lunedi 20 Aprile 2026
# - custom template with {date} {weekday} {month} {month_number} {day} {year}
# JOURNAL_NOTE_TITLE_FORMAT=iso

# Telegram notifications (optional)
# TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather

# Email notifications via SMTP (optional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=your@gmail.com
# SMTP_TLS=true
# APP_BASE_URL=https://notevault.yourdomain.com
